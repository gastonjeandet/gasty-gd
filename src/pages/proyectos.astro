---
<Layout
  title="Proyectos — Gasty Jeandet"
  description="Portfolio completo de Gastón Jeandet: streaming, gamificación, juegos, audiovisual y teatro."
>
  <!-- NAV -->
  <nav class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-6 py-4" style="background: rgba(10,10,10,0.97); border-bottom: 1px solid var(--color-border);">
    <a href="/" class="font-bold text-sm tracking-widest transition-colors hover:opacity-80" style="font-family:'Space Grotesk',sans-serif; color: var(--color-lime);">← GASTY.GD</a>
    <a href="/cv-gasty-jeandet.pdf" download class="text-sm font-bold transition-colors hover:opacity-80" style="font-family:'Space Grotesk',sans-serif; color: var(--color-lime);">↓ Descargar CV</a>
  </nav>

  <main class="pt-24 pb-24 px-6 max-w-5xl mx-auto">
    <p class="section-label mb-4">Portfolio completo</p>
    <h1 class="text-5xl sm:text-7xl mb-4" style="font-family:'Space Grotesk',sans-serif;">Proyectos</h1>
    <p class="text-lg mb-20" style="color: var(--color-muted);">Todo lo que hice, en detalle.</p>

    {secciones.map((seccion) => (
      <section class="mb-24">
        <h2 class="text-2xl mb-10 pb-4" style="font-family:'Space Grotesk',sans-serif; border-bottom: 1px solid var(--color-border);">
          {seccion.area}
        </h2>
        <div class="space-y-12">
          {seccion.proyectos.map((p, pi) => (
            <div class="grid md:grid-cols-3 gap-8 items-start">
              {p.galeria && p.galeria.length ? (
                <div class="md:col-span-1">
                  <div
                    class="relative"
                    data-carrusel={JSON.stringify(p.galeria)}
                    style="border-radius: 2px; overflow: hidden; background: #000;"
                  >
                    <div style="aspect-ratio: 4/3; background:#000;">
                      <img
                        class="car-img w-full h-full"
                        src={p.galeria[0]}
                        alt={p.titulo}
                        style="object-fit: contain; background:#000;"
                        loading="lazy"
                      />
                    </div>
                    {p.galeria.length > 1 && (
                      <>
                        <button type="button" data-dir="-1" aria-label="Anterior" style="position:absolute;left:6px;top:50%;transform:translateY(-50%);width:34px;height:34px;border:0;border-radius:50%;background:rgba(0,0,0,0.6);color:#fff;font-size:1.2rem;cursor:pointer;backdrop-filter:blur(4px);">‹</button>
                        <button type="button" data-dir="1" aria-label="Siguiente" style="position:absolute;right:6px;top:50%;transform:translateY(-50%);width:34px;height:34px;border:0;border-radius:50%;background:rgba(0,0,0,0.6);color:#fff;font-size:1.2rem;cursor:pointer;backdrop-filter:blur(4px);">›</button>
                        <div style="position:absolute;top:6px;right:8px;font-size:0.65rem;font-weight:700;padding:2px 7px;background:rgba(0,0,0,0.6);color:#fff;border-radius:99px;backdrop-filter:blur(4px);"><span class="car-num">1</span>/{p.galeria.length}</div>
                      </>
                    )}
                  </div>
                </div>
              ) : (
                <div class="md:col-span-1 flex items-center justify-center text-5xl" style="aspect-ratio:4/3; background: var(--color-surface); border-radius: 2px;">
                  🎬
                </div>
              )}
              <div class="md:col-span-2">
                <p class="text-xs mb-2" style="color: var(--color-lime); font-family:'Space Grotesk',sans-serif; letter-spacing:0.1em;">{p.periodo}</p>
                <h3 class="text-2xl mb-1" style="font-family:'Space Grotesk',sans-serif;">{p.titulo}</h3>
                <p class="text-sm mb-4" style="color: var(--color-muted);">{p.rol}</p>
                <p class="text-sm mb-6" style="color: #bbb; line-height: 1.7;">{p.descripcion}</p>
                {p.links.length > 0 && (
                  <div class="flex flex-wrap gap-3">
                    {p.links.map((link) => (
                      <a
                        href={link.url}
                        target="_blank"
                        rel="noopener"
                        class="inline-flex items-center gap-2 text-xs font-bold px-4 py-2 transition-colors hover:opacity-80"
                        style="background: var(--color-lime); color: #000; font-family:'Space Grotesk',sans-serif; border-radius: 2px;"
                      >
                        {link.label} ↗
                      </a>
                    ))}
                  </div>
                )}
              </div>
            </div>
          ))}
        </div>
      </section>
    ))}
  </main>

  <footer class="py-8 px-6 text-center text-xs" style="color: var(--color-muted); border-top: 1px solid var(--color-border);">
    <a href="/" class="hover:text-white transition-colors">← Volver al inicio</a>
    <span class="mx-4" style="color: var(--color-border);">|</span>
    <span>© {new Date().getFullYear()} Gastón Jeandet</span>
  </footer>
</Layout>

<script is:inline>
  document.querySelectorAll('[data-carrusel]').forEach((el) => {
    const imgs = JSON.parse(el.dataset.carrusel);
    if (imgs.length < 2) return;
    let idx = 0;
    const imgEl = el.querySelector('.car-img');
    const numEl = el.querySelector('.car-num');
    const ir = (delta) => {
      idx = (idx + delta + imgs.length) % imgs.length;
      imgEl.src = imgs[idx];
      if (numEl) numEl.textContent = (idx + 1);
    };
    el.querySelectorAll('[data-dir]').forEach((btn) => {
      btn.addEventListener('click', () => ir(Number(btn.dataset.dir)));
    });
  });
</script>
